{
  "manifest_version": 3,
  "name": "SignBridge — Sign Language for Google Meet",
  "short_name": "SignBridge",
  "version": "1.0.0",
  "description": "Real-time sign language recognition and translation for Google Meet using AI/ML.",
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    },
    "default_title": "SignBridge"
  },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": [
        "content/content.js"
      ],
      "css": [],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabCapture",
    "identity",
    "tabs",
    "notifications"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "http://localhost:8000/*",
    "ws://localhost:8000/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content/signDetector.js",
        "content/speechSynthesis.js",
        "content/avatarRenderer.js",
        "content/meetingRecorder.js",
        "content/uiOverlay.js",
        "assets/icons/*",
        "assets/avatar/*"
      ],
      "matches": ["https://meet.google.com/*"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "optional_permissions": ["microphone", "camera"]
}
