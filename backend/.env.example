# SignBridge Environment Variables

# 1. Google Gemini API Key
# Get this from Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# 2. JWT Configuration for User Authentication
# Generate a secret key. In python you can use: import secrets; secrets.token_hex(32)
JWT_SECRET_KEY=put-your-256-bit-secret-key-here

# 3. Database URL
# Default is SQLite for easy local setup.
# PostgreSQL format: postgresql://user:password@localhost/dbname
DATABASE_URL=sqlite:///./signbridge.db

# 4. Machine Learning Model Path
# Path to the trained Keras/TensorFlow H5 model
MODEL_PATH=./models/sign_model.h5

# 5. Core Settings
MAX_FRAME_QUEUE=30
CONFIDENCE_THRESHOLD=0.75
WS_MAX_CONNECTIONS=100
